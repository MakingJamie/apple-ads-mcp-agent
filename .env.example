# Apple Search Ads API Credentials
# Generate at: Apple Search Ads → Settings → API tab
# Certificate valid for 24 months

APPLE_ADS_TEAM_ID=your_team_id
APPLE_ADS_CLIENT_ID=your_client_id
APPLE_ADS_KEY_ID=your_key_id
APPLE_ADS_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

# Org ID — find in Apple Ads dashboard URL: searchads.apple.com/cm/app/overview?orgId=XXXXXXX
APPLE_ADS_ORG_ID=your_org_id

# Optional: default currency (ISO 4217) for bids and budgets. Set this to your
# Apple Ads account currency (e.g. EUR, GBP, USD). Defaults to USD if unset.
APPLE_ADS_CURRENCY=USD

# Optional: your app's App Store ID (adamId). When set, create_campaign defaults
# to it so you don't have to pass it on every call. Find it in your App Store URL:
# apps.apple.com/app/id<THIS_NUMBER>. If unset, adamId is required per call.
APPLE_ADS_DEFAULT_ADAM_ID=
